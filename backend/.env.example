# ══════════════════════════════════════════════════════════════════════════════
# Variabile de mediu – Food Waste Combat Platform
# Copiați în .env și ajustați valorile!
# ══════════════════════════════════════════════════════════════════════════════

# ── Aplicație ─────────────────────────────────────────────────────────────────
DEBUG=False

# ── PostgreSQL + PostGIS ───────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/foodsave_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generați o cheie sigură: openssl rand -hex 32
SECRET_KEY=SCHIMBA_ACEASTA_CHEIE_CU_CEVA_RANDOM_DE_MINIM_32_CARACTERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
